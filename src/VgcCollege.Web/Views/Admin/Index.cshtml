@model oop_s2_1_mvc_76214.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Administrator Dashboard";
}

<h1>Administrator Dashboard</h1>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-controller="Branches" asp-action="Index" class="btn btn-outline-primary">Manage Branches</a>
    <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-primary">Manage Courses</a>
    <a asp-controller="StudentProfiles" asp-action="Index" class="btn btn-outline-primary">Manage Student Profiles</a>
    <a asp-controller="StaffAssignments" asp-action="Index" class="btn btn-outline-primary">Manage Staff Assignments</a>
    <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary">Manage Users</a>
    <a asp-controller="Enrolments" asp-action="Index" class="btn btn-primary">Manage Enrolments</a>
</div>

<div class="row g-3 mt-1">
    <div class="col-md-3">
        <div class="card"><div class="card-body"><h6>Branches</h6><p class="fs-4">@Model.BranchCount</p></div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><h6>Courses</h6><p class="fs-4">@Model.CourseCount</p></div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><h6>Students</h6><p class="fs-4">@Model.StudentCount</p></div></div>
    </div>
    <div class="col-md-3">
        <div class="card"><div class="card-body"><h6>Faculty</h6><p class="fs-4">@Model.FacultyCount</p></div></div>
    </div>
</div>
