@model IEnumerable<oop_s2_1_mvc_76214.Models.ViewModels.FacultyCourseViewModel>
@{
    ViewData["Title"] = "Faculty Dashboard";
}

<h1>Faculty Dashboard</h1>
<p>Courses assigned to you.</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Students</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseName</td>
            <td>@item.BranchName</td>
            <td>@item.StudentCount</td>
            <td>
                <a asp-action="Students" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-primary">View Students</a>
                <a asp-action="Attendance" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-success">Attendance</a>
            </td>
        </tr>
    }
    </tbody>
</table>
