@model IEnumerable<oop_s2_1_mvc_76214.Models.ViewModels.EnrolmentListItemViewModel>
@{
    ViewData["Title"] = "Enrolments";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Enrolments</h1>
        <small class="text-muted">Manage course registrations for students.</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Enrolment</a>
</div>

<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Student</th>
            <th>Student #</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Enrol Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.StudentName</td>
            <td>@item.StudentNumber</td>
            <td>@item.CourseName</td>
            <td>@item.BranchName</td>
            <td>@item.EnrolDate.ToString("yyyy-MM-dd")</td>
            <td>
                <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary")">@item.Status</span>
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
