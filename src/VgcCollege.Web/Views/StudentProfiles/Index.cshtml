@model IEnumerable<oop_s2_1_mvc_76214.Models.StudentProfile>
@{
    ViewData["Title"] = "Student Profiles";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Student Profiles</h1>
    <a asp-action="Create" class="btn btn-primary">New Student Profile</a>
</div>

<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Student #</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.StudentNumber</td>
            <td>@item.Email</td>
            <td>@item.Phone</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
