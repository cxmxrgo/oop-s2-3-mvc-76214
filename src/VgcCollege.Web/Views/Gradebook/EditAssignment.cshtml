@model oop_s2_1_mvc_76214.Models.ViewModels.AssignmentEditViewModel
@{
    ViewData["Title"] = "Edit Assignment";
}

<h1>Edit Assignment</h1>
<p class="text-muted">@Model.CourseName</p>

<div class="card shadow-sm">
<div class="card-body">
<form asp-action="EditAssignment" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="CourseId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MaxScore" class="form-label"></label>
        <input asp-for="MaxScore" asp-format="{0:0.##}" class="form-control" type="number" min="1" max="100" step="0.01" />
        <span asp-validation-for="MaxScore" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Assignments" asp-route-courseId="@Model.CourseId" class="btn btn-secondary">Cancel</a>
</form>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
