@model IEnumerable<oop_s2_1_mvc_76214.Models.ViewModels.AssignmentListItemViewModel>
@{
    ViewData["Title"] = "Assignments";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Assignments</h1>
        <small class="text-muted">@ViewBag.CourseName</small>
    </div>
    <a asp-action="CreateAssignment" asp-route-courseId="@ViewBag.CourseId" class="btn btn-primary">New Assignment</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Title</th>
            <th>Max Score</th>
            <th>Due Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.MaxScore</td>
            <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
            <td>
                <a asp-action="EditAssignment" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="AssignmentResults" asp-route-assignmentId="@item.Id" class="btn btn-sm btn-outline-success">Gradebook</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-outline-secondary">Back to Courses</a>
