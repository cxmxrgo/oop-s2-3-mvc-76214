@model IEnumerable<oop_s2_1_mvc_76214.Models.ViewModels.ExamListItemViewModel>
@{
    ViewData["Title"] = "Exams";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-0">Exams</h1>
        <small class="text-muted">@ViewBag.CourseName</small>
    </div>
    <a asp-action="CreateExam" asp-route-courseId="@ViewBag.CourseId" class="btn btn-primary">New Exam</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Title</th>
            <th>Max Score</th>
            <th>Date</th>
            <th>Release Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.MaxScore</td>
            <td>@item.Date.ToString("yyyy-MM-dd")</td>
            <td>
                <span class="badge @(item.ResultsReleased ? "bg-success" : "bg-warning text-dark")">
                    @(item.ResultsReleased ? "Released" : "Not Released")
                </span>
            </td>
            <td>
                <a asp-action="EditExam" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="ExamResults" asp-route-examId="@item.Id" class="btn btn-sm btn-outline-success">Results</a>
                @if (ViewBag.IsAdmin == true)
                {
                    <form asp-action="ToggleRelease" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="examId" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-dark">
                            @(item.ResultsReleased ? "Unrelease" : "Release")
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-outline-secondary">Back to Courses</a>
