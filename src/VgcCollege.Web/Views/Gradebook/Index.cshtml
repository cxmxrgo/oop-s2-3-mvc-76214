@model IEnumerable<oop_s2_1_mvc_76214.Models.ViewModels.GradebookCourseViewModel>
@{
    ViewData["Title"] = "Gradebook";
}

<h1>Gradebook</h1>
<p class="text-muted">Manage assignments, exams, and results by course.</p>

<div class="table-responsive">
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Students</th>
            <th>Assignments</th>
            <th>Exams</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CourseName</td>
            <td>@item.BranchName</td>
            <td>@item.StudentCount</td>
            <td>@item.AssignmentCount</td>
            <td>@item.ExamCount</td>
            <td>
                <a asp-action="Assignments" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-primary">Assignments</a>
                <a asp-action="Exams" asp-route-courseId="@item.CourseId" class="btn btn-sm btn-outline-success">Exams</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
