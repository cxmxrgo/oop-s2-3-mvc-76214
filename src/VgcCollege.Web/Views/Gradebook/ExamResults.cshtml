@model oop_s2_1_mvc_76214.Models.ViewModels.ExamResultsViewModel
@{
    ViewData["Title"] = "Exam Results";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<h1>Exam Results</h1>
<p class="text-muted">@Model.CourseName - @Model.ExamTitle (Max: @Model.MaxScore.ToString("0.##"))</p>
<p class="text-muted">Allowed score range: 0-100</p>

<div class="mb-3">
    <span class="badge @(Model.ResultsReleased ? "bg-success" : "bg-warning text-dark")">
        @(Model.ResultsReleased ? "Released to Students" : "Not Released")
    </span>
</div>

<form asp-action="ExamResults" method="post">
    <input asp-for="ExamId" type="hidden" />
    <input asp-for="CourseId" type="hidden" />
    <input asp-for="CourseName" type="hidden" />
    <input asp-for="ExamTitle" type="hidden" />
    <input asp-for="MaxScore" type="hidden" />
    <input asp-for="ResultsReleased" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Student</th>
                <th>Student #</th>
                <th>Score</th>
                <th>Grade</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Students.Count; i++)
        {
            <tr>
                <td>
                    @Model.Students[i].StudentName
                    <input asp-for="Students[i].StudentProfileId" type="hidden" />
                    <input asp-for="Students[i].StudentName" type="hidden" />
                </td>
                <td>
                    @Model.Students[i].StudentNumber
                    <input asp-for="Students[i].StudentNumber" type="hidden" />
                </td>
                <td>
                    <input asp-for="Students[i].Score" asp-format="{0:0.##}" class="form-control" type="number" min="0" max="100" step="0.01" />
                    <span asp-validation-for="Students[i].Score" class="text-danger"></span>
                </td>
                <td>
                    <input asp-for="Students[i].Grade" class="form-control" />
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>

    <button type="submit" class="btn btn-primary">Save Results</button>
    <a asp-action="Exams" asp-route-courseId="@Model.CourseId" class="btn btn-secondary">Back to Exams</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
