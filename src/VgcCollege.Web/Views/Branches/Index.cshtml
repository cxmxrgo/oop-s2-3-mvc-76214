@model IEnumerable<oop_s2_1_mvc_76214.Models.Branch>
@{
    ViewData["Title"] = "Branches";
}

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-info">@statusMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Branches</h1>
    <a asp-action="Create" class="btn btn-primary">New Branch</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Address</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
